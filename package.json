{
  "name": "agent-envoy",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Envoy monorepo for OpenClaw and Hermes envoy plugins.",
  "workspaces": [
    "openclaw-envoy"
  ],
  "scripts": {
    "test:openclaw": "npm --prefix openclaw-envoy test",
    "typecheck:openclaw": "npm --prefix openclaw-envoy run typecheck",
    "build:openclaw": "npm --prefix openclaw-envoy run build",
    "validate:openclaw": "npm --prefix openclaw-envoy run plugin:validate"
  }
}
